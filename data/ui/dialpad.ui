<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="Dialpad" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">12</property>
    <property name="margin-top">24</property>
    <property name="margin-bottom">24</property>
    <property name="margin-start">24</property>
    <property name="margin-end">24</property>

    <!-- Account selector (hidden when only one account registered) -->
    <child>
      <object class="GtkDropDown" id="account_selector">
        <property name="visible">false</property>
        <property name="hexpand">true</property>
      </object>
    </child>

    <!-- Number entry -->
    <child>
      <object class="GtkBox">
        <property name="spacing">6</property>
        <child>
          <object class="GtkEntry" id="number_entry">
            <property name="hexpand">true</property>
            <property name="placeholder-text">Enter number…</property>
            <property name="input-purpose">phone</property>
            <property name="xalign">0.5</property>
            <style><class name="title-2"/></style>
            <signal name="activate" handler="on_entry_activate" swapped="yes"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="delete_button">
            <property name="icon-name">edit-clear-symbolic</property>
            <property name="valign">center</property>
            <property name="tooltip-text">Delete last digit</property>
            <signal name="clicked" handler="on_delete_clicked" swapped="yes"/>
            <style><class name="flat"/></style>
          </object>
        </child>
      </object>
    </child>

    <!-- Digit grid -->
    <child>
      <object class="GtkGrid">
        <property name="row-spacing">6</property>
        <property name="column-spacing">6</property>
        <property name="halign">center</property>

        <!-- Row 0 -->
        <child><object class="GtkButton"><property name="label">1</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">0</property><property name="row">0</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">2</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">1</property><property name="row">0</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">3</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">2</property><property name="row">0</property></layout></object></child>

        <!-- Row 1 -->
        <child><object class="GtkButton"><property name="label">4</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">0</property><property name="row">1</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">5</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">1</property><property name="row">1</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">6</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">2</property><property name="row">1</property></layout></object></child>

        <!-- Row 2 -->
        <child><object class="GtkButton"><property name="label">7</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">0</property><property name="row">2</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">8</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">1</property><property name="row">2</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">9</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">2</property><property name="row">2</property></layout></object></child>

        <!-- Row 3 -->
        <child><object class="GtkButton"><property name="label">*</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">0</property><property name="row">3</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">0</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">1</property><property name="row">3</property></layout></object></child>
        <child><object class="GtkButton"><property name="label">#</property><signal name="clicked" handler="on_digit_clicked" swapped="yes"/><style><class name="pill"/><class name="dialpad-key"/></style><layout><property name="column">2</property><property name="row">3</property></layout></object></child>
      </object>
    </child>

    <!-- Call button -->
    <child>
      <object class="GtkButton" id="call_button">
        <property name="icon-name">call-start-symbolic</property>
        <property name="halign">center</property>
        <property name="tooltip-text">Call</property>
        <signal name="clicked" handler="on_call_clicked" swapped="yes"/>
        <style>
          <class name="circular"/>
          <class name="suggested-action"/>
          <class name="dialpad-call"/>
        </style>
      </object>
    </child>

  </template>
</interface>

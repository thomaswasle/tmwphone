<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="SettingsDialog" parent="AdwPreferencesDialog">
    <property name="title">Preferences</property>
    <property name="content-width">360</property>
    <property name="content-height">640</property>
    <child>
      <object class="AdwPreferencesPage" id="accounts_page">
        <property name="title">Accounts</property>
        <property name="icon-name">avatar-default-symbolic</property>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesPage">
        <property name="title">Audio</property>
        <property name="icon-name">audio-headphones-symbolic</property>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title">Devices</property>
            <property name="description">Audio device selection requires a restart.</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>

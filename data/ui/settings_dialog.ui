<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="SettingsDialog" parent="AdwPreferencesDialog">
    <property name="title">Preferences</property>
    <child>
      <object class="AdwPreferencesPage">
        <property name="title">Account</property>
        <property name="icon-name">avatar-default-symbolic</property>

        <child>
          <object class="AdwPreferencesGroup">
            <property name="title">SIP Account</property>
            <child>
              <object class="AdwEntryRow" id="display_name_row">
                <property name="title">Display name</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="username_row">
                <property name="title">Username</property>
              </object>
            </child>
            <child>
              <object class="AdwPasswordEntryRow" id="password_row">
                <property name="title">Password</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="server_row">
                <property name="title">SIP server</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="AdwPreferencesGroup">
            <child>
              <object class="AdwButtonRow" id="connect_row">
                <property name="title">Save and Connect</property>
                <style><class name="suggested-action"/></style>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>

    <child>
      <object class="AdwPreferencesPage">
        <property name="title">Audio</property>
        <property name="icon-name">audio-headphones-symbolic</property>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title">Devices</property>
            <property name="description">Audio device selection requires a restart.</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
